## Data Fetching Patterns

### TanStack Query with Validation

```typescript
// ✅ REQUIRED - Type-safe queries with Zod validation
export function useUsersQuery(params?: { page?: number; search?: string }) {
  return useQuery({
    queryKey: ["users", params],
    queryFn: async (): Promise<UsersResponse> => {
      const response = await api.get("/users", { params });
      return usersResponseSchema.parse(response); // Runtime validation
    },
    staleTime: 5 * 60 * 1000,
  });
}

// ✅ REQUIRED - Mutation with error handling
export function useCreateUser() {
  const queryClient = useQueryClient();
  
  return useMutation({
    mutationFn: (data: UserCreateData) => {
      const validatedData = userCreateSchema.parse(data);
      return api.post("/users", validatedData);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ["users"] });
      notifications.show({
        title: "Success",
        message: "User created successfully",
        color: "green",
      });
    },
    onError: (error: ApiError) => {
      notifications.show({
        title: "Error", 
        message: error.message,
        color: "red",
      });
    },
  });
}
```

## Form Handling Standards

### Zod + Mantine Integration

```typescript
// ✅ REQUIRED - Complete form pattern
const userFormSchema = z.object({
  name: z.string().min(2, "Name must be at least 2 characters"),
  email: z.string().email("Invalid email address"),
  role: z.enum(["admin", "user", "manager"]),
});

type UserFormData = z.infer<typeof userFormSchema>;

export function UserForm({ onSuccess }: { onSuccess?: (user: User) => void }) {
  const form = useForm<UserFormData>({
    initialValues: { name: "", email: "", role: "user" },
    validate: zodResolver(userFormSchema),
  });

  const mutation = useCreateUser({
    onSuccess: (user) => {
      form.reset();
      onSuccess?.(user);
    },
  });

  return (
    <form onSubmit={form.onSubmit((values) => mutation.mutate(values))}>
      <LoadingOverlay visible={mutation.isPending} />
      
      <Stack gap="md">
        <TextInput
          label="Full Name"
          required
          {...form.getInputProps("name")}
        />
        
        <TextInput
          label="Email"
          type="email"
          required
          {...form.getInputProps("email")}
        />
        
        <Select
          label="Role"
          required
          data={[
            { value: "user", label: "User" },
            { value: "admin", label: "Administrator" },
            { value: "manager", label: "Manager" },
          ]}
          {...form.getInputProps("role")}
        />

        <Button type="submit" loading={mutation.isPending}>
          Create User
        </Button>
      </Stack>
    </form>
  );
}
```

