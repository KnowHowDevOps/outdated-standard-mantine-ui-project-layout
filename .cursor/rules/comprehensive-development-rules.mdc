# Comprehensive Development Rules

## Architecture Enforcement (CRITICAL)

### Feature-Sliced Design Boundaries

**NEVER VIOLATE**: Layer import hierarchy and public API rules.

```typescript
// ✅ ALLOWED IMPORTS
import { Button } from "@/shared/ui";           // features → shared
import { User } from "@/entities/user";         // features → entities  
import { UserForm } from "@/features/user";     // pages → features

// ❌ FORBIDDEN IMPORTS
import { UserForm } from "@/features/user";     // shared → features
import { Dashboard } from "@/pages/dashboard";  // features → pages
import { AuthForm } from "@/features/auth";     // features → features
```

### Public API Only

```typescript
// ✅ CORRECT - Through public API
import { UserCard, useUserQuery } from "@/entities/user";

// ❌ WRONG - Bypassing public API
import { UserCard } from "@/entities/user/ui/user-card";
```

## Type Safety Requirements

### Zod-First Development

```typescript
// ✅ REQUIRED PATTERN - Schema first, then types
import { z } from "zod";

export const userSchema = z.object({
  id: z.string().uuid(),
  name: z.string().min(1).max(100),
  email: z.string().email(),
  role: z.enum(["admin", "user", "manager"]),
});

export type User = z.infer<typeof userSchema>;

// ❌ FORBIDDEN - Types without runtime validation
export interface User {
  id: string;
  name: string;
  // No runtime validation
}
```

### Strict TypeScript Compliance

```typescript
// ✅ REQUIRED - Proper null safety
function processUser(user: User | null | undefined) {
  if (!user) return null;
  
  // TypeScript knows user is defined here
  return user.name.toUpperCase();
}

// ❌ FORBIDDEN - Unsafe array access
function getFirstUser(users: User[]): User {
  return users[0]; // Type error with noUncheckedIndexedAccess
}
```

## Component Development Standards

### React 19 Patterns

```typescript
// ✅ REQUIRED - Suspense for loading states
function UserProfilePage({ userId }: { userId: string }) {
  return (
    <Suspense fallback={<UserProfileSkeleton />}>
      <UserProfile userId={userId} />
    </Suspense>
  );
}

// ✅ REQUIRED - Proper memoization
export const UserCard = memo<UserCardProps>(
  ({ user, onEdit, onDelete }) => {
    const handleEdit = useCallback(() => onEdit(user), [user, onEdit]);
    const handleDelete = useCallback(() => onDelete(user.id), [user.id, onDelete]);
    
    return (
      <Card>
        <Text>{user.name}</Text>
        <Group>
          <Button onClick={handleEdit}>Edit</Button>
          <Button onClick={handleDelete}>Delete</Button>
        </Group>
      </Card>
    );
  }
);
```

