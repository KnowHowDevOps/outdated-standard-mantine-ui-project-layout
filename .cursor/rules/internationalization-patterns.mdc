# Internationalization (i18n) Patterns with Lingui

## Lingui Macro Usage

### Basic Translation Patterns

**RULE**: Always use Lingui macros for user-facing text.

```typescript
// ✅ CORRECT - Using Lingui macros
import { Trans, t } from "@lingui/macro";
import { useLingui } from "@lingui/react";

function UserWelcome({ user }: { user: User }) {
  const { _ } = useLingui();
  
  return (
    <div>
      {/* Component text with Trans */}
      <h1><Trans>Welcome back, {user.name}!</Trans></h1>
      
      {/* Programmatic text with t macro */}
      <button 
        title={_(t`Edit user profile`)}
        aria-label={_(t`Edit profile for ${user.name}`)}
      >
        <Trans>Edit Profile</Trans>
      </button>
      
      {/* Conditional translations */}
      <p>
        {user.isOnline ? (
          <Trans>You are currently online</Trans>
        ) : (
          <Trans>You are offline</Trans>
        )}
      </p>
    </div>
  );
}

// ❌ WRONG - Hardcoded strings
function UserWelcomeBad({ user }: { user: User }) {
  return (
    <div>
      <h1>Welcome back, {user.name}!</h1>  {/* Not translatable */}
      <button title="Edit user profile">Edit Profile</button>
    </div>
  );
}
```

### Pluralization Patterns

```typescript
// ✅ CORRECT - Proper pluralization
import { Plural } from "@lingui/macro";

function NotificationCount({ count }: { count: number }) {
  return (
    <div>
      <Plural
        value={count}
        zero="No new notifications"
        one="# new notification"
        other="# new notifications"
      />
    </div>
  );
}

function UserStats({ userCount, activeCount }: { 
  userCount: number; 
  activeCount: number; 
}) {
  return (
    <div>
      <p>
        <Plural
          value={userCount}
          zero="No users registered"
          one="One user registered"
          other="# users registered"
        />
      </p>
      
      <p>
        <Plural
          value={activeCount}
          zero="None are currently active"
          one="# is currently active"
          other="# are currently active"
        />
      </p>
    </div>
  );
}
```

### Context-Aware Translations

```typescript
// ✅ CORRECT - Context for disambiguation
import { t } from "@lingui/macro";

function ActionButtons({ context }: { context: "user" | "product" | "order" }) {
  const { _ } = useLingui();
  
  // Different contexts for the same word
  const getDeleteLabel = () => {
    switch (context) {
      case "user":
        return _(t`Delete user`);
      case "product":
        return _(t`Delete product`);
      case "order":
        return _(t`Cancel order`);
      default:
        return _(t`Delete`);
    }
  };
  
  return (
    <Group>
      <Button variant="subtle">
        <Trans>Edit</Trans>
      </Button>
      <Button color="red">
        {getDeleteLabel()}
      </Button>
    </Group>
  );
}
```

## Date and Number Formatting

### Locale-Aware Formatting

```typescript
// ✅ CORRECT - Locale-aware date/number formatting
import { useLingui } from "@lingui/react";
import dayjs from "dayjs";
import "dayjs/locale/en";
import "dayjs/locale/es";
import "dayjs/locale/fr";

function UserActivity({ user, lastLogin, postCount }: {
  user: User;
  lastLogin: Date;
  postCount: number;
}) {
  const { i18n } = useLingui();
  
  // Format dates according to current locale
  const formatDate = (date: Date) => {
    return dayjs(date)
      .locale(i18n.locale)
      .format("LLL"); // Localized format
  };
  
  // Format numbers according to current locale
  const formatNumber = (num: number) => {
    return new Intl.NumberFormat(i18n.locale).format(num);
  };
  
  // Format currency
  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat(i18n.locale, {
      style: "currency",
      currency: "USD", // Could be dynamic based on user preference
    }).format(amount);
  };
  
  return (
    <Stack gap="sm">
      <Text>
        <Trans>Last login: {formatDate(lastLogin)}</Trans>
      </Text>
      
      <Text>
        <Trans>Total posts: {formatNumber(postCount)}</Trans>
      </Text>
      
      {user.accountBalance && (
        <Text>
          <Trans>Account balance: {formatCurrency(user.accountBalance)}</Trans>
        </Text>
      )}
    </Stack>
  );
}
```

### Relative Time Formatting

```typescript
// ✅ CORRECT - Relative time with i18n
import { useLingui } from "@lingui/react";
import dayjs from "dayjs";
import relativeTime from "dayjs/plugin/relativeTime";

dayjs.extend(relativeTime);

function RelativeTimeDisplay({ date }: { date: Date }) {
  const { i18n } = useLingui();
  
  const getRelativeTime = () => {
    return dayjs(date)
      .locale(i18n.locale)
      .fromNow();
  };
  
  return (
    <Text c="dimmed" size="sm">
      {getRelativeTime()}
    </Text>
  );
}
```

## Locale Management

### Locale Switcher Component

```typescript
// ✅ CORRECT - Comprehensive locale switcher
import { Select } from "@mantine/core";
import { useLingui } from "@lingui/react";
import { Trans } from "@lingui/macro";

const SUPPORTED_LOCALES = [
  { value: "en", label: "English", flag: "🇺🇸" },
  { value: "es", label: "Español", flag: "🇪🇸" },
  { value: "fr", label: "Français", flag: "🇫🇷" },
  { value: "de", label: "Deutsch", flag: "🇩🇪" },
] as const;

export function LocaleSwitcher() {
  const { i18n } = useLingui();
  
  const handleLocaleChange = async (locale: string) => {
    // Dynamically import locale data
    const { messages } = await import(`../locales/${locale}/messages`);
    i18n.load(locale, messages);
    i18n.activate(locale);
    
    // Persist locale preference
    localStorage.setItem("locale", locale);
    
    // Update document language
    document.documentElement.lang = locale;
    
    // Optionally update URL or notify parent components
    window.dispatchEvent(new CustomEvent("localeChange", { detail: locale }));
  };
  
  return (
    <Select
      label={<Trans>Language</Trans>}
      value={i18n.locale}
      onChange={handleLocaleChange}
      data={SUPPORTED_LOCALES.map(locale => ({
        value: locale.value,
        label: `${locale.flag} ${locale.label}`,
      }))}
      searchable={false}
      allowDeselect={false}
    />
  );
}
```

### Locale Detection and Initialization

```typescript
// ✅ CORRECT - Locale detection and setup
// app/i18n.ts
import { i18n } from "@lingui/core";

const SUPPORTED_LOCALES = ["en", "es", "fr", "de"];
const DEFAULT_LOCALE = "en";

async function detectLocale(): Promise<string> {
  // 1. Check URL parameter
  const urlParams = new URLSearchParams(window.location.search);
  const urlLocale = urlParams.get("locale");
  if (urlLocale && SUPPORTED_LOCALES.includes(urlLocale)) {
    return urlLocale;
  }
  
  // 2. Check localStorage
  const savedLocale = localStorage.getItem("locale");
  if (savedLocale && SUPPORTED_LOCALES.includes(savedLocale)) {
    return savedLocale;
  }
  
  // 3. Check browser language
  const browserLocale = navigator.language.split("-")[0];
  if (SUPPORTED_LOCALES.includes(browserLocale)) {
    return browserLocale;
  }
  
  // 4. Fall back to default
  return DEFAULT_LOCALE;
}

export async function initializeI18n() {
  const locale = await detectLocale();
  
  // Load messages for detected locale
  const { messages } = await import(`../locales/${locale}/messages`);
  
  i18n.load(locale, messages);
  i18n.activate(locale);
  
  // Set document language
  document.documentElement.lang = locale;
  
  return locale;
}
```

## Form Validation with i18n

### Translated Validation Messages

```typescript
// ✅ CORRECT - Internationalized validation
import { z } from "zod";
import { t } from "@lingui/macro";
import { useLingui } from "@lingui/react";

function createUserValidationSchema() {
  const { _ } = useLingui();
  
  return z.object({
    name: z.string()
      .min(2, _(t`Name must be at least 2 characters`))
      .max(50, _(t`Name must be less than 50 characters`)),
    
    email: z.string()
      .email(_(t`Please enter a valid email address`)),
    
    age: z.number()
      .min(18, _(t`You must be at least 18 years old`))
      .max(120, _(t`Please enter a valid age`)),
    
    role: z.enum(["admin", "user", "manager"], {
      errorMap: () => ({ message: _(t`Please select a valid role`) })
    }),
  });
}

function UserForm() {
  const validationSchema = createUserValidationSchema();
  
  const form = useForm({
    validate: zodResolver(validationSchema),
    // ... other form config
  });
  
  return (
    <form onSubmit={form.onSubmit(handleSubmit)}>
      <TextInput
        label={<Trans>Full Name</Trans>}
        placeholder={_(t`Enter your full name`)}
        {...form.getInputProps("name")}
      />
      
      <TextInput
        label={<Trans>Email Address</Trans>}
        placeholder={_(t`your.email@example.com`)}
        {...form.getInputProps("email")}
      />
      
      <NumberInput
        label={<Trans>Age</Trans>}
        placeholder={_(t`Enter your age`)}
        {...form.getInputProps("age")}
      />
      
      <Select
        label={<Trans>Role</Trans>}
        placeholder={_(t`Select your role`)}
        data={[
          { value: "user", label: _(t`User`) },
          { value: "admin", label: _(t`Administrator`) },
          { value: "manager", label: _(t`Manager`) },
        ]}
        {...form.getInputProps("role")}
      />
    </form>
  );
}
```

## Error Messages and Notifications

### Internationalized Error Handling

```typescript
// ✅ CORRECT - Translated error messages
import { notifications } from "@mantine/notifications";
import { t } from "@lingui/macro";
import { useLingui } from "@lingui/react";

function useApiErrorHandler() {
  const { _ } = useLingui();
  
  const handleError = (error: ApiError) => {
    let title: string;
    let message: string;
    
    switch (error.type) {
      case "validation":
        title = _(t`Validation Error`);
        message = _(t`Please check your input and try again`);
        break;
        
      case "auth":
        title = _(t`Authentication Error`);
        message = _(t`Please log in and try again`);
        break;
        
      case "network":
        title = _(t`Network Error`);
        message = _(t`Please check your connection and try again`);
        break;
        
      case "server":
        title = _(t`Server Error`);
        message = _(t`Something went wrong on our end. Please try again later.`);
        break;
        
      default:
        title = _(t`Error`);
        message = _(t`An unexpected error occurred`);
    }
    
    notifications.show({
      title,
      message,
      color: "red",
    });
  };
  
  return { handleError };
}
```

## Component Library Integration

### Mantine Components with i18n

```typescript
// ✅ CORRECT - Mantine components with proper i18n
import { DataTable } from "mantine-datatable";
import { Trans, t } from "@lingui/macro";
import { useLingui } from "@lingui/react";

function UsersDataTable({ users }: { users: User[] }) {
  const { _ } = useLingui();
  
  return (
    <DataTable
      records={users}
      columns={[
        {
          accessor: "name",
          title: _(t`Name`),
        },
        {
          accessor: "email", 
          title: _(t`Email`),
        },
        {
          accessor: "role",
          title: _(t`Role`),
          render: ({ role }) => {
            const roleLabels = {
              admin: _(t`Administrator`),
              user: _(t`User`),
              manager: _(t`Manager`),
            };
            return roleLabels[role] || role;
          },
        },
        {
          accessor: "status",
          title: _(t`Status`),
          render: ({ status }) => {
            const statusLabels = {
              active: _(t`Active`),
              inactive: _(t`Inactive`),
              pending: _(t`Pending`),
            };
            return (
              <Badge color={status === "active" ? "green" : "gray"}>
                {statusLabels[status] || status}
              </Badge>
            );
          },
        },
      ]}
      noRecordsText={_(t`No users found`)}
      loadingText={_(t`Loading users...`)}
      // ... other props
    />
  );
}
```

## Message Extraction Workflow

### Proper Message Organization

```typescript
// ✅ CORRECT - Organized message extraction
// Use descriptive IDs for complex messages
import { defineMessage } from "@lingui/macro";

export const messages = {
  userWelcome: defineMessage({
    id: "user.welcome",
    message: "Welcome back, {name}! You have {count, plural, =0 {no new messages} one {# new message} other {# new messages}}.",
  }),
  
  confirmDelete: defineMessage({
    id: "user.confirmDelete",
    message: "Are you sure you want to delete {name}? This action cannot be undone.",
  }),
  
  validationErrors: {
    required: defineMessage({
      id: "validation.required",
      message: "This field is required",
    }),
    email: defineMessage({
      id: "validation.email", 
      message: "Please enter a valid email address",
    }),
  },
};

// Usage in components
function UserComponent({ user }: { user: User }) {
  const { _ } = useLingui();
  
  return (
    <div>
      <h1>{_(messages.userWelcome, { name: user.name, count: user.messageCount })}</h1>
    </div>
  );
}
```