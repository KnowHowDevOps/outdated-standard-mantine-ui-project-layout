## Component Composition Patterns

### Compound Components

```typescript
// ✅ CORRECT - Compound component pattern
import { Card, Group, Text, Badge, ActionIcon } from "@mantine/core";
import { IconEdit, IconTrash } from "@tabler/icons-react";

interface UserCardProps {
  user: User;
  children?: React.ReactNode;
}

function UserCard({ user, children }: UserCardProps) {
  return (
    <Card shadow="sm" padding="lg" radius="md" withBorder>
      {children}
    </Card>
  );
}

function UserCardHeader({ user, onEdit, onDelete }: {
  user: User;
  onEdit?: (user: User) => void;
  onDelete?: (userId: string) => void;
}) {
  return (
    <Group justify="space-between" mb="md">
      <div>
        <Text fw={500}>{user.name}</Text>
        <Text c="dimmed" size="sm">{user.email}</Text>
      </div>
      
      <Group gap="xs">
        <Badge color={user.status === "active" ? "green" : "gray"}>
          {user.status}
        </Badge>
        
        {onEdit && (
          <ActionIcon 
            variant="subtle" 
            onClick={() => onEdit(user)}
            aria-label={`Edit ${user.name}`}
          >
            <IconEdit size="1rem" />
          </ActionIcon>
        )}
        
        {onDelete && (
          <ActionIcon 
            variant="subtle" 
            color="red"
            onClick={() => onDelete(user.id)}
            aria-label={`Delete ${user.name}`}
          >
            <IconTrash size="1rem" />
          </ActionIcon>
        )}
      </Group>
    </Group>
  );
}

// Usage
<UserCard user={user}>
  <UserCard.Header user={user} onEdit={handleEdit} onDelete={handleDelete} />
  <UserCard.Body>
    <Text size="sm">Additional content...</Text>
  </UserCard.Body>
</UserCard>
```

## Form Patterns with Mantine

### Form Component Structure

```typescript
// ✅ CORRECT - Mantine form with validation
import { useForm, zodResolver } from "@mantine/form";
import { 
  TextInput, 
  Select, 
  Button, 
  Stack, 
  Group,
  LoadingOverlay 
} from "@mantine/core";
import { notifications } from "@mantine/notifications";

interface UserFormProps {
  user?: User;
  onSuccess?: (user: User) => void;
  onCancel?: () => void;
}

export function UserForm({ user, onSuccess, onCancel }: UserFormProps) {
  const form = useForm<UserFormData>({
    initialValues: {
      name: user?.name || "",
      email: user?.email || "",
      role: user?.role || "user",
    },
    validate: zodResolver(userFormSchema),
  });

  const mutation = useCreateUser({
    onSuccess: (newUser) => {
      notifications.show({
        title: "Success",
        message: "User created successfully",
        color: "green",
      });
      form.reset();
      onSuccess?.(newUser);
    },
  });

  return (
    <form onSubmit={form.onSubmit((values) => mutation.mutate(values))}>
      <LoadingOverlay visible={mutation.isPending} />
      
      <Stack gap="md">
        <TextInput
          label="Full Name"
          placeholder="Enter full name"
          required
          {...form.getInputProps("name")}
        />
        
        <TextInput
          label="Email Address"
          placeholder="user@example.com"
          type="email"
          required
          {...form.getInputProps("email")}
        />
        
        <Select
          label="Role"
          placeholder="Select role"
          required
          data={[
            { value: "user", label: "User" },
            { value: "admin", label: "Administrator" },
            { value: "manager", label: "Manager" },
          ]}
          {...form.getInputProps("role")}
        />

        <Group justify="flex-end" mt="lg">
          {onCancel && (
            <Button variant="subtle" onClick={onCancel}>
              Cancel
            </Button>
          )}
          <Button type="submit" loading={mutation.isPending}>
            Create User
          </Button>
        </Group>
      </Stack>
    </form>
  );
}
```

## Data Display Patterns

### DataTable with Mantine

```typescript
// ✅ CORRECT - Mantine DataTable integration
import { DataTable } from "mantine-datatable";
import { Badge, Group, ActionIcon, Text } from "@mantine/core";
import { IconEdit, IconTrash } from "@tabler/icons-react";

interface UsersTableProps {
  users: User[];
  onEdit: (user: User) => void;
  onDelete: (userId: string) => void;
  loading?: boolean;
}

export function UsersTable({ users, onEdit, onDelete, loading }: UsersTableProps) {
  return (
    <DataTable
      records={users}
      columns={[
        {
          accessor: "name",
          title: "Name",
          render: ({ name, email }) => (
            <div>
              <Text fw={500}>{name}</Text>
              <Text c="dimmed" size="sm">{email}</Text>
            </div>
          ),
        },
        {
          accessor: "role",
          title: "Role",
          render: ({ role }) => (
            <Badge variant="light">
              {role}
            </Badge>
          ),
        },
        {
          accessor: "status",
          title: "Status",
          render: ({ status }) => (
            <Badge color={status === "active" ? "green" : "gray"}>
              {status}
            </Badge>
          ),
        },
        {
          accessor: "actions",
          title: "Actions",
          textAlign: "right",
          render: (user) => (
            <Group gap="xs" justify="flex-end">
              <ActionIcon
                variant="subtle"
                onClick={() => onEdit(user)}
                aria-label={`Edit ${user.name}`}
              >
                <IconEdit size="1rem" />
              </ActionIcon>
              <ActionIcon
                variant="subtle"
                color="red"
                onClick={() => onDelete(user.id)}
                aria-label={`Delete ${user.name}`}
              >
                <IconTrash size="1rem" />
              </ActionIcon>
            </Group>
          ),
        },
      ]}
      fetching={loading}
      highlightOnHover
      striped
      verticalSpacing="sm"
      minHeight={200}
      noRecordsText="No users found"
    />
  );
}
```

## Accessibility Patterns

### ARIA and Semantic HTML

```typescript
// ✅ CORRECT - Accessible Mantine components
import { Modal, Button, TextInput, Alert } from "@mantine/core";
import { IconAlertCircle } from "@tabler/icons-react";

function AccessibleModal({ opened, onClose, title, children }: {
  opened: boolean;
  onClose: () => void;
  title: string;
  children: React.ReactNode;
}) {
  return (
    <Modal
      opened={opened}
      onClose={onClose}
      title={title}
      aria-labelledby="modal-title"
      aria-describedby="modal-description"
    >
      <div id="modal-description">
        {children}
      </div>
    </Modal>
  );
}

function AccessibleForm() {
  const [error, setError] = useState<string | null>(null);
  
  return (
    <form role="form" aria-labelledby="form-title">
      <h2 id="form-title">User Registration</h2>
      
      {error && (
        <Alert
          icon={<IconAlertCircle size="1rem" />}
          color="red"
          role="alert"
          aria-live="assertive"
          mb="md"
        >
          {error}
        </Alert>
      )}
      
      <TextInput
        label="Email"
        required
        type="email"
        aria-describedby="email-help"
        error={error}
        aria-invalid={Boolean(error)}
      />
      
      <Text id="email-help" size="sm" c="dimmed">
        We'll never share your email with anyone else.
      </Text>
      
      <Button type="submit" mt="md">
        Register
      </Button>
    </form>
  );
}
```

## Performance Patterns

### Memoization with Mantine

```typescript
// ✅ CORRECT - Optimized Mantine components
import { memo, useMemo } from "react";
import { DataTable } from "mantine-datatable";

interface OptimizedUserTableProps {
  users: User[];
  searchQuery?: string;
  sortBy?: string;
}

export const OptimizedUserTable = memo<OptimizedUserTableProps>(
  ({ users, searchQuery, sortBy }) => {
    const filteredAndSortedUsers = useMemo(() => {
      let result = [...users];
      
      // Filter
      if (searchQuery) {
        result = result.filter(user =>
          user.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
          user.email.toLowerCase().includes(searchQuery.toLowerCase())
        );
      }
      
      // Sort
      if (sortBy) {
        result.sort((a, b) => {
          const aValue = a[sortBy as keyof User];
          const bValue = b[sortBy as keyof User];
          return String(aValue).localeCompare(String(bValue));
        });
      }
      
      return result;
    }, [users, searchQuery, sortBy]);

    return (
      <DataTable
        records={filteredAndSortedUsers}
        // ... other props
      />
    );
  }
);

OptimizedUserTable.displayName = "OptimizedUserTable";
```

