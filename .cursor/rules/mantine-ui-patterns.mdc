# Mantine UI Development Patterns

## Theme Integration

### Theme Configuration

**RULE**: Always use theme tokens instead of hardcoded values.

```typescript
// ✅ CORRECT - Using theme tokens
import { createTheme, MantineColorsTuple } from "@mantine/core";

const brandBlue: MantineColorsTuple = [
  "#e7f5ff", "#d0ebff", "#a5d8ff", "#74c0fc", 
  "#339af0", "#228be6", "#1c7ed6", "#1971c2", 
  "#1864ab", "#0b5394"
];

export const theme = createTheme({
  primaryColor: "brandBlue",
  colors: { brandBlue },
  fontFamily: "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
  defaultRadius: "md",
  spacing: {
    xs: "0.5rem",
    sm: "0.75rem", 
    md: "1rem",
    lg: "1.5rem",
    xl: "2rem",
  },
});

// ❌ WRONG - Hardcoded values
const styles = {
  padding: "16px",        // Use theme.spacing.md
  color: "#228be6",       // Use theme.colors.brandBlue[5]
  borderRadius: "8px",    // Use theme.radius.md
};
```

### Component Styling Patterns

```typescript
// ✅ CORRECT - Theme-aware component styling
import { Box, Card, Text } from "@mantine/core";
import classes from "./user-card.module.css";

function UserCard({ user }: { user: User }) {
  return (
    <Card
      shadow="sm"
      padding="lg"
      radius="md"
      withBorder
      className={classes.card}
    >
      <Text fw={500} size="lg" mb="xs">
        {user.name}
      </Text>
      
      <Text c="dimmed" size="sm">
        {user.email}
      </Text>
      
      {/* Use theme spacing */}
      <Box mt="md" p="sm" bg="gray.0">
        Role: {user.role}
      </Box>
    </Card>
  );
}
```

## Responsive Design Patterns

### Responsive Props

```typescript
// ✅ CORRECT - Responsive component design
import { Container, SimpleGrid, Title, Text } from "@mantine/core";

function ResponsiveLayout({ children }: { children: React.ReactNode }) {
  return (
    <Container size="xl">
      <Title 
        order={{ base: 2, sm: 1 }}
        size={{ base: "h3", sm: "h2", lg: "h1" }}
        mb={{ base: "sm", sm: "md", lg: "lg" }}
      >
        Dashboard
      </Title>
      
      <SimpleGrid
        cols={{ base: 1, sm: 2, lg: 3 }}
        spacing={{ base: "sm", sm: "md", lg: "lg" }}
        verticalSpacing={{ base: "sm", sm: "md", lg: "lg" }}
      >
        {children}
      </SimpleGrid>
    </Container>
  );
}
```

