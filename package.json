{
  "name": "@iqkv/standard-mantine-ui-project-layout",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -b && pnpm messages:extract && pnpm messages:compile && vite build",
    "ci": "pnpm ci:lint && pnpm ci:test",
    "ci:lint": "pnpm lint",
    "ci:test": "pnpm test",
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:all-browsers": "cross-env ALL_BROWSERS=true playwright test",
    "e2e:chrome": "playwright test --project=chromium",
    "e2e:debug": "cross-env PWDEBUG=1 playwright test",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:smoke": "playwright test smoke",
    "e2e:ui": "playwright test --ui",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:webkit": "playwright test --project=webkit",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:stylelint": "stylelint \"**/*.css\" --aei",
    "messages:compile": "lingui compile",
    "messages:extract": "lingui extract",
    "node_modules:clear": "rm -rf node_modules",
    "playwright:install": "playwright install --with-deps",
    "prepare": "husky",
    "prettier:check": "prettier . --check --ignore-unknown",
    "prettier:write": "prettier . --write",
    "preview": "vite preview",
    "release": "release-it --ci",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest run --ui",
    "test:wath": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*": [
      "pnpm prettier:check"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
