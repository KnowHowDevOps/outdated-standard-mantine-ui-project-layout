# API Configuration
VITE_API_BASE_URL=https://api.example.com

# Development Settings
VITE_ENABLE_MSW=true
VITE_LOG_LEVEL=info

# MSW (Mock Service Worker) Configuration
# Enable/disable MSW mocking (true/false)
VITE_ENABLE_MSW=true
# Response delay in milliseconds (0 for no delay, or number for fixed delay)
VITE_MSW_DELAY=500
# Enable MSW request/response logging (true/false)
VITE_MSW_LOGGING=true

# Optional: Authentication
VITE_AUTH_ENDPOINT=https://auth.example.com
VITE_CLIENT_ID=your-client-id